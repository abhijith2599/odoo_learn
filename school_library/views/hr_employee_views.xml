<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_academic" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.academic</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Academic Profile" name="academic_profile">
                    <group>
                        <field name="employee_type"/>
                        <field name="specialization_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
