<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_library_book_issue_list" model="ir.ui.view">
        <field name="name">library.book.issue.list</field>
        <field name="model">library.book.issue</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-warning="state == 'issued'" decoration-success="state == 'returned'">
                <field name="book_id"/>
                <field name="student_id"/>
                <field name="issue_date"/>
                <field name="return_date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'issued'" decoration-success="state == 'returned'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_library_book_issue_form" model="ir.ui.view">
        <field name="name">library.book.issue.form</field>
        <field name="model">library.book.issue</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,issued,returned"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="book_id"/>
                            <field name="student_id"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="return_date"/>
                        </group>
                    </group>
                    <group string="Additional Notes">
                        <field name="notes" placeholder="Remarks, book condition, or other details..." nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_library_book_issue_kanban" model="ir.ui.view">
        <field name="name">library.book.issue.kanban</field>
        <field name="model">library.book.issue</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="fw-bold">
                            <field name="book_id"/>
                        </div>
                        <div class="text-muted">
                            <span>Student: <field name="student_id"/></span>
                        </div>
                        <footer>
                            <div>
                                <span>Issue Date: <field name="issue_date"/></span>
                            </div>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_library_book_issue_search" model="ir.ui.view">
        <field name="name">library.book.issue.search</field>
        <field name="model">library.book.issue</field>
        <field name="arch" type="xml">
            <search>
                <field name="book_id" string="Book"/>
                <field name="student_id" string="Student"/>
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Issued" name="state_issued" domain="[('state', '=', 'issued')]"/>
                <filter string="Returned" name="state_returned" domain="[('state', '=', 'returned')]"/>
                <group expand="0" string="Group By">
                    <filter string="Book" name="group_by_book" context="{'group_by': 'book_id'}"/>
                    <filter string="Student" name="group_by_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_library_book_issue" model="ir.actions.act_window">
        <field name="name">Book Issues</field>
        <field name="res_model">library.book.issue</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first book issue request!
            </p>
        </field>
    </record>
</odoo>
