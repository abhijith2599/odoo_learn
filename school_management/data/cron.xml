<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_daily_absent_notification" model="ir.cron">
            <field name="name">Daily Absent Notification</field>
            <field name="model_id" ref="model_school_student"/>
            <field name="state">code</field>
            <field name="code">model._cron_absent_notification()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>

        <record id="cron_monthly_fee_reminder" model="ir.cron">
            <field name="name">Monthly Fee Reminder</field>
            <field name="model_id" ref="model_school_student"/>
            <field name="state">code</field>
            <field name="code">model._cron_fee_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
        </record>
    </data>
</odoo>
