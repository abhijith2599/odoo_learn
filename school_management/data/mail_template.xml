<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_enrollment_confirmation" model="mail.template">
            <field name="name">Student Enrollment Confirmation</field>
            <field name="model_id" ref="school_management.model_school_student"/>
            <field name="subject">Welcome to {{ object.class_id.name }}!</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="description">Sent to students upon enrollment</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333333;">
                    <p style="margin: 0px; padding: 0px; font-size: 14px;">
                        Dear <strong><t t-out="object.name or 'Student'"></t></strong>,<br/><br/>
                        Congratulations! You have been successfully enrolled in <strong><t t-out="object.class_id.name or 'our school'"></t></strong>.<br/><br/>
                        Your official Registration/Roll Number is: <strong><t t-out="object.roll_number or 'Pending'"></t></strong><br/><br/>
                        We are thrilled to welcome you. Please contact the administration office if you have any questions before classes start.<br/><br/>
                        Best Regards,<br/>
                        <strong>School Management Team</strong>
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
