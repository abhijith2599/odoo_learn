<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_school_class_list" model="ir.ui.view">
        <field name="name">school.class.list</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="teacher_id"/>
                <field name="student_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_class_form" model="ir.ui.view">
        <field name="name">school.class.form</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_students"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-graduation-cap">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Grade 5-A"/>
                        </h1>
                    </div>
                    <group>
                        <field name="teacher_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <notebook>
                        <page string="Students" name="students">
                            <field name="student_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="roll_number"/>
                                    <field name="gender"/>
                                    <field name="date_of_birth"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_school_class_kanban" model="ir.ui.view">
        <field name="name">school.class.kanban</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-baseline">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                        </div>
                        <footer class="align-items-end">
                            <div>
                                <span>Students: <field name="student_count"/></span>
                            </div>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_school_class_search" model="ir.ui.view">
        <field name="name">school.class.search</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Class Name"/>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_school_class" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">school.class</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first class!
            </p>
        </field>
    </record>
</odoo>
