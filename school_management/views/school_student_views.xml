<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_school_student_list" model="ir.ui.view">
        <field name="name">school.student.list</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="roll_number"/>
                <field name="gender"/>
                <field name="class_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'applied'" decoration-success="state == 'enrolled'" decoration-danger="state == 'rejected'"/>
                <field name="date_of_birth"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_student_form" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_apply" string="Apply" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_enroll" string="Enroll" type="object" class="oe_highlight" invisible="state != 'applied'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'applied'"/>
                    <button name="%(action_report_student_id_card)d" string="Print ID Card" type="action" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,applied,enrolled,rejected"/>
                </header>
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Alice Smith"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="roll_number"/>
                            <field name="gender"/>
                            <field name="blood_group"/>
                        </group>
                        <group>
                            <field name="class_id"/>
                            <field name="date_of_birth"/>
                            <field name="email"/>
                            <field name="guardian_phone"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_school_student_kanban" model="ir.ui.view">
        <field name="name">school.student.kanban</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <kanban default_group_by="class_id" class="o_kanban_mobile">
                <field name="class_id"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-baseline">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                        </div>
                        <div class="text-muted">
                            <span>Roll Number: <field name="roll_number"/></span>
                        </div>
                        <footer class="align-items-end">
                            <div>
                                <span>Gender: <field name="gender"/></span>
                            </div>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_school_student_search" model="ir.ui.view">
        <field name="name">school.student.search</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <search>
                <!-- Search fields -->
                <field name="name" string="Student Name"/>
                <field name="roll_number" string="Roll Number"/>
                <field name="class_id" string="Class"/>

                <!-- Filters -->
                <filter string="Male" name="filter_male" domain="[('gender', '=', 'male')]"/>
                <filter string="Female" name="filter_female" domain="[('gender', '=', 'female')]"/>
                <filter string="Other" name="filter_other" domain="[('gender', '=', 'other')]"/>

                <separator/>

                <!-- Group by -->
                <group expand="0" string="Group By">
                    <filter string="Class" name="group_by_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Gender" name="group_by_gender" context="{'group_by': 'gender'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_school_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.student</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first student!
            </p>
        </field>
    </record>
</odoo>
