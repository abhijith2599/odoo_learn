<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_bulk_enroll_wizard_form" model="ir.ui.view">
        <field name="name">school.bulk.enroll.wizard.form</field>
        <field name="model">school.bulk.enroll.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Enroll">
                <sheet>
                    <group>
                        <field name="class_id"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Enroll" type="object" name="action_enroll" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action Window in Server Action Dropdown -->
    <record id="action_bulk_enroll_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Enroll</field>
        <field name="res_model">school.bulk.enroll.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="school_management.model_school_student"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
