<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Category -->
    <record model="ir.module.category" id="module_category_school_management">
        <field name="name">School Management</field>
        <field name="description">Security for School Management</field>
        <field name="sequence">10</field>
    </record>

    <!-- Groups -->
    <record id="group_school_parent" model="res.groups">
        <field name="name">Parent</field>
        <field name="category_id" ref="module_category_school_management"/>
    </record>

    <record id="group_school_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="category_id" ref="module_category_school_management"/>
        <field name="implied_ids" eval="[(4, ref('group_school_parent'))]"/>
    </record>

    <record id="group_school_accounts" model="res.groups">
        <field name="name">Accounts</field>
        <field name="category_id" ref="module_category_school_management"/>
        <field name="implied_ids" eval="[(4, ref('group_school_teacher'))]"/>
    </record>

    <record id="group_school_principal" model="res.groups">
        <field name="name">Principal</field>
        <field name="category_id" ref="module_category_school_management"/>
        <field name="implied_ids" eval="[(4, ref('group_school_accounts'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="rule_student_parent" model="ir.rule">
        <field name="name">Parent sees only own children</field>
        <field name="model_id" ref="model_school_student"/>
        <field name="domain_force">[('guardian_email', '=', user.login)]</field>
        <field name="groups" eval="[(4, ref('group_school_parent'))]"/>
    </record>

    <record id="rule_student_teacher" model="ir.rule">
        <field name="name">Teacher sees only own class students</field>
        <field name="model_id" ref="model_school_student"/>
        <field name="domain_force">[('class_id.teacher_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_school_teacher'))]"/>
    </record>

    <record id="rule_student_principal" model="ir.rule">
        <field name="name">Principal sees all students</field>
        <field name="model_id" ref="model_school_student"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_school_principal'))]"/>
    </record>

    <record id="rule_student_accounts" model="ir.rule">
        <field name="name">Accounts sees all students</field>
        <field name="model_id" ref="model_school_student"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_school_accounts'))]"/>
    </record>

    <!-- Multi-Company Rules -->
    <record id="rule_student_company" model="ir.rule">
        <field name="name">Student Multi-Company</field>
        <field name="model_id" ref="model_school_student"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_class_company" model="ir.rule">
        <field name="name">Class Multi-Company</field>
        <field name="model_id" ref="model_school_class"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
